---
import { SEOMetadata } from 'astro-seo-metadata';

export interface Props {
  title: string;
}

const { title } = Astro.props;

const ogImage = new URL("/og-image.png", Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-7M9FKP2465"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-7M9FKP2465');
    </script>
    <!-- Astro -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="stylesheet" href="/como.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wdth,wght@8..144,25..151,100..900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&display=swap"
      />
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wdth,wght@8..144,25..151,100..900&display=swap"
      />
    </noscript>

    <!-- SEO -->
    <SEOMetadata
      siteName={'uwucrew by Kusari'}
      title={title}
      description={'Immerse yourself into the future of anime art ✨ Join the Kusari Family and let\'s empower creativity together 🎨🌈 Connect with others inspired by anime!'}
      image={ogImage}
      favicon={'/favicon.ico'}
      author="uwucrew"
      astroSitemap={true}
      canonicalUrl={Astro.url.toString()}
      type={'website'}
      astroGenerator={true}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
<style is:global>
  :root {
    --main: #1c1f22;
    --bg: #f4f5f6;
    --sub: #545357;
    --primary: #f2a7c8;
  }

  * {
    font-family: "como", sans-serif;
    color: var(--main);
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-size: 10px;
    text-transform: lowercase;
  }
  button {
    background: none;
    border: none;
    outline: none;
  }

  input {
    border: none;
    outline: none;
  }

  a {
    text-decoration: none;
  }
</style>
